rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper: authenticated via Google OAuth
    function isGoogleAuth() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    // Helper: user has admin custom claim (set via Firebase Admin SDK)
    function isAdmin() {
      return isGoogleAuth() && request.auth.token.admin == true;
    }

    match /evidence/{imageFile} {
      // Any Google-authenticated player can read puzzle evidence images
      allow read: if isGoogleAuth();

      // Only admins can upload / overwrite evidence images
      allow write: if isAdmin()
        // Limit file size to 10 MB
        && request.resource.size < 10 * 1024 * 1024
        // Accept common image MIME types only
        && request.resource.contentType.matches('image/.*');

      // Deletes are admin-only
      allow delete: if isAdmin();
    }
  }
}
